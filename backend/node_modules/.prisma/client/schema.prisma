generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── User (Staff & Customers) ───────────────────────────────────
model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  passwordHash String?
  role         String // ADMIN | ACCOUNT_MANAGER | DESIGNER | DEVELOPER | QA | CUSTOMER
  isActive     Boolean @default(true)

  managedTickets   Ticket[] @relation("AccountManager")
  designedTickets  Ticket[] @relation("Designer")
  developedTickets Ticket[] @relation("Developer")
  qaTickets        Ticket[] @relation("QA")
  customerTickets  Ticket[] @relation("Customer")

  notifications Notification[]
  auditLogs     AuditLog[]
}

// ─── Client Info (Onboarding Data) ──────────────────────────────
model ClientInfo {
  id              String   @id @default(uuid())
  customerName    String
  email           String?
  phone           String?
  nationalId      String?
  iban            String?
  businessName    String
  industry        String
  description     String
  targetAudience  String
  hasDocument     Boolean  @default(false)
  documentFileUrl String?
  legalDocUrl     String?
  hasLegalDoc     Boolean  @default(true)
  nationalIdUrl   String?
  fullNameInId    String?
  absherPhone     String?
  tickets         Ticket[]
}

// ─── AI Proposal ────────────────────────────────────────────────
model AIProposal {
  id               String  @id @default(uuid())
  selectedColors   String // JSON string of colors
  brandVoice       String?
  brandVision      String?
  brandDescription String?
  suggestedNames   String
  businessName     String?
  description      String?
  industry         String?
  referenceLogos   String?
  generatedLogoUrl String?
  selectedName     String?
  ticketId         String  @unique
  ticket           Ticket  @relation(fields: [ticketId], references: [id])
}

// ─── Store Details (IT Credentials) ─────────────────────────────
model StoreDetails {
  id                       String  @id @default(uuid())
  sallaStoreUrl            String?
  domainName               String?
  storeEmail               String?
  storePasswordEncrypted   String?
  isProPurchased           Boolean @default(false)
  paymentGatewayConfigured Boolean @default(false)
  ticketId                 String  @unique
  ticket                   Ticket  @relation(fields: [ticketId], references: [id])
}

// ─── Ticket (Order Pipeline) ────────────────────────────────────
model Ticket {
  id             String   @id @default(uuid())
  stage          String   @default("INTAKE")
  stageEnteredAt DateTime @default(now())
  isSlaBreached  Boolean  @default(false)
  checklists     String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // ── Workflow Engine Additions ────────────────────────────────
  amPasswordVisibility  Boolean   @default(false)
  staffAcceptedAt       DateTime?
  staffNotes            String?
  assetsUrl             String?
  designLogoUrl         String?
  designBannersUrl      String?
  designCategoriesUrl   String?
  customerApproved      Boolean   @default(false)
  customSlaHours        Int?
  amInstructions        String?
  designerInstructions  String?
  developerInstructions String?
  qaInstructions        String?
  deliveredSiteUrl      String? // Live website URL set when AM approves → DELIVERED

  clientId String
  client   ClientInfo @relation(fields: [clientId], references: [id])

  aiProposal   AIProposal?
  storeDetails StoreDetails?

  accountManagerId String?
  accountManager   User?   @relation("AccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)

  designerId String?
  designer   User?   @relation("Designer", fields: [designerId], references: [id], onDelete: SetNull)

  developerId String?
  developer   User?   @relation("Developer", fields: [developerId], references: [id], onDelete: SetNull)

  qaId String?
  qa   User?   @relation("QA", fields: [qaId], references: [id], onDelete: SetNull)

  customerId String?
  customer   User?   @relation("Customer", fields: [customerId], references: [id], onDelete: SetNull)

  notifications Notification[]
  auditLogs     AuditLog[]
}

// ─── Notification ──────────────────────────────────────────────
model Notification {
  id         String   @id @default(uuid())
  userId     String?
  role       String?
  ticketId   String?
  title      String
  message    String
  isRead     Boolean  @default(false)
  isPriority Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])
}

// ─── Audit Log (Action Trail) ──────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  action    String // e.g. "ASSIGNED_STAFF", "TOGGLED_PASSWORD", "STAGE_CHANGED"
  details   String? // Optional JSON metadata
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
